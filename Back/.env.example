# EduVoice Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env files with real credentials!

# ============================================
# Google Gemini API Configuration
# ============================================
# Get it from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Eleven Labs TTS Configuration
# ============================================
# Get it from: https://elevenlabs.io/
ELEVEN_LABS_API_KEY=your_eleven_labs_api_key_here

# Voice ID - find yours at: https://elevenlabs.io/docs/api-reference/get-voices
# Default: "21m00Tcm4TlvDq8ikWAM" (Bella voice)
ELEVEN_LABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# Firebase Configuration (Production Storage)
# ============================================
# Firebase Project ID
# Get from: Firebase Console > Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Storage Bucket
# Format: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Credentials (as JSON string - from service account key)
# IMPORTANT: Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Then copy the JSON content as a single line string
# Command to convert: cat .firebase-credentials.json | jq -r 'tojson' | tr -d '"'
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...complete json..."}

# Alternatively, use Firebase Credentials file path (for local development only)
# DO NOT USE IN PRODUCTION - use FIREBASE_CREDENTIALS_JSON instead
FIREBASE_CREDENTIALS_PATH=.firebase-credentials.json

# ============================================
# Google OAuth Configuration (Frontend Login)
# ============================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Application Settings
# ============================================
DEBUG=False

# CORS Origins (comma-separated for production)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Request timeout in seconds
REQUEST_TIMEOUT=30

# App Version
APP_VERSION=1.0.0
APP_NAME=EduVoice

# CORS_ORIGINS=https://yourdomain.com
